{
  "name": "wx-codex",
  "version": "0.1.0-alpha.2",
  "description": "Local MCP server and CLI bridge from Codex to WeChat DevTools.",
  "type": "module",
  "bin": {
    "wx-codex": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "cli": "node dist/cli/main.js",
    "detect": "node dist/cli/detect-devtools.js",
    "doctor": "node dist/cli/doctor.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  },
  "author": {
    "name": "Ivar Yang"
  },
  "keywords": [
    "codex",
    "mcp",
    "wechat",
    "wechat-miniprogram",
    "weapp",
    "devtools",
    "mini-program"
  ],
  "homepage": "https://github.com/ivar8990/wx-codex#readme",
