.page {
  min-height: 100vh;
  padding: 48rpx 36rpx;
  box-sizing: border-box;
  background: #f8fafc;
}

.hero {
  padding: 32rpx 0 28rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 18rpx;
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.title {
  display: block;
  color: #111827;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.12;
}

.status {
  display: block;
  margin-top: 18rpx;
  color: #0f766e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.45;
}

.tagline {
  display: block;
  margin-top: 16rpx;
  color: #475569;
  font-size: 26rpx;
  line-height: 1.45;
}

.panel {
  margin-top: 34rpx;
  padding: 8rpx 0;
}

.step {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.marker {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  margin-right: 22rpx;
  border-radius: 8rpx;
  background: #0f766e;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.step-text {
  flex: 1;
  color: #1f2937;
  font-size: 28rpx;
  line-height: 1.35;
}
