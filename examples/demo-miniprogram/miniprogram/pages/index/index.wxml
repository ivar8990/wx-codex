<view class="page">
  <view class="hero">
    <text class="eyebrow">MVP Demo</text>
    <text class="title">{{title}}</text>
    <text class="status">{{status}}</text>
    <text class="tagline">{{tagline}}</text>
  </view>

  <view class="panel">
    <block wx:for="{{steps}}" wx:key="*this">
      <view class="step">
        <text class="marker">{{index + 1}}</text>
        <text class="step-text">{{item}}</text>
      </view>
    </block>
  </view>
</view>
